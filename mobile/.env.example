# Web app URL loaded inside the Android WebView
EXPO_PUBLIC_WEB_APP_URL=https://shirwell-shipping.vercel.app/

# Google AdMob — https://admob.google.com/
# Create an Android app + Banner ad unit in AdMob console.
# Leave unset during development to use Google test IDs.
# EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
# EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID=ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz
# EXPO_PUBLIC_ADMOB_ENABLED=false
